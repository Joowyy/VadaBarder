<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:paddingBottom="60dp"
    android:background="@color/gray_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:fontFamily="@font/roboto"
            android:text="@string/NombreApp"
            android:textAllCaps="true"
            android:textSize="62sp"
            android:textStyle="bold"

            android:shadowColor="#80000000"
            android:shadowRadius="6"
            android:shadowDx="3"
            android:shadowDy="3"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- TITULO -->
        <TextView
            android:id="@+id/tituloCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pedir cita"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:background="@drawable/bg_titulos"
            android:layout_marginTop="8dp"

            android:shadowColor="#40000000"
            android:shadowRadius="3"
            android:shadowDx="1"
            android:shadowDy="2"

            app:layout_constraintTop_toBottomOf="@id/textView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- CALENDARIO -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/materialCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tituloCita">

            <CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.card.MaterialCardView>

        <!-- TEXTO HORAS -->
        <TextView
            android:id="@+id/textHoras"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_titulos"
            android:text="Horas disponibles"
            android:textColor="@color/black"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"

            android:shadowColor="#40000000"
            android:shadowRadius="3"
            android:shadowDx="1"
            android:shadowDy="2"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/materialCardView" />


        <!-- LISTA DE HORAS -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupHoras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="invisible"
            app:singleSelection="true"
            android:layout_marginTop="6dp"
            app:chipSpacing="12dp"
            app:layout_constraintTop_toBottomOf="@id/textHoras"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- TEXTO SERVICIOS -->
        <TextView
            android:id="@+id/textServicios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Servicio (opcional)"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="@color/black"
            android:background="@drawable/bg_titulos"
            android:layout_marginTop="14dp"

            android:shadowColor="#40000000"
            android:shadowRadius="3"
            android:shadowDx="1"
            android:shadowDy="2"

            app:layout_constraintTop_toBottomOf="@id/chipGroupHoras"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- SERVICIOS -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="invisible"
            app:singleSelection="true"
            android:layout_marginTop="6dp"
            app:chipSpacing="12dp"
            app:layout_constraintTop_toBottomOf="@id/textServicios"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>

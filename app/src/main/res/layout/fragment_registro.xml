<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light"
    tools:context=".ui.register.RegistroFragment">

    <!-- VADABARBER -->
    <TextView
        android:id="@+id/textView"
        style="@style/VadaBarber.AppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/NombreApp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Formulario centrado -->
    <LinearLayout
        android:id="@+id/formGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="36dp"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.44">

        <!-- Título + acento -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CREAR CUENTA"
                android:textAllCaps="true"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.08"
                android:fontFamily="@font/grotesk"
                android:textColor="@color/text_primary_light"/>

            <View
                android:layout_width="44dp"
                android:layout_height="3dp"
                android:background="@color/deep_purple_500"
                android:layout_marginTop="5dp"
                android:layout_gravity="center_horizontal"/>
        </LinearLayout>

        <!-- Nombre de usuario -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de usuario"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary_light"
            android:letterSpacing="0.04"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/editTextNombre"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/edittext_draw"
            android:hint="Nombre de usuario..."
            android:textAlignment="center"
            android:inputType="text"
            android:layout_marginBottom="16dp"/>

        <!-- Correo -->
        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correo electrónico"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary_light"
            android:letterSpacing="0.04"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/editTextCorreo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/edittext_draw"
            android:hint="Correo..."
            android:textAlignment="center"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"/>

        <!-- Contraseña -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary_light"
            android:letterSpacing="0.04"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/editTextPsswd"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/edittext_draw"
            android:hint="Contraseña..."
            android:textAlignment="center"
            android:inputType="textPassword"
            android:layout_marginBottom="14dp"/>

        <!-- Recordar usuario -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbRecordar"
            style="@style/VadaBarber.CheckBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recordar usuario"
            android:layout_marginBottom="20dp"/>

        <!-- Botón -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistro"
            style="@style/VadaBarber.Button.CTA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REGISTRARSE"
            android:layout_marginBottom="36dp"/>

        <!-- Link login -->
        <LinearLayout
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Ya tienes cuenta?  "
                android:textSize="14sp"
                android:textColor="@color/text_secondary_light"/>

            <TextView
                android:id="@+id/camInicioSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="Iniciar sesión"
                android:textColor="@color/deep_purple_500"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
